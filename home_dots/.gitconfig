[user]
	email = andre.arroxellas@tuta.io
	name = André Arroxellas
[github]
	user = aarroxellas
[alias]
	st = status -sb
	ci = commit
	all = commit -am
	br = branch
	co = checkout
	di = diff
	dic = diff --cached
	lg = log -p
	lol = log --graph --decorate --pretty=oneline --abbre-commit
	lola = log --graph --decorate --pretty=oneline --abbre-commit -- all
	ls = ls-files
	# Show files ignored by git:
	ign = ls-files -o -i --exclude-standard
	shoot = push origin --delete
	unstage = reset HEAD --
	prev = checkout -
	discard = checkout --

[color]
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[core]
	whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
	editor = nvim
	quotepath = false
	excludesfile = ~/.gitignore
	hooksPath = ~/.config/git/hooks
[mergetool]
	keepBackup = true
[filter "lfs"]
	process = git-lts filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[push]
	default = current
[url "git@github.com"]
	insteadOf = https://github.com/
[pull]
	rebase = false
[init]
	defaultBranch = main
